{
  "expo": {
    "name": "CactusGemma",
    "slug": "cactusgemma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cactuscompute.cactusgemma",
      "appleTeamId": "943JL46954",
      "entitlements": {
        "com.apple.developer.kernel.increased-memory-limit": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jakubcac.cactusgemma",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Microphone access for voice input — hold to speak your question."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access for visual AI — take a photo and ask Gemma about it.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a4ff8222-a54e-4adf-beb0-dd93e19a91d1"
      }
    },
    "owner": "cactus-organization"
  }
}
